{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sony eBook Library Revival",
  "version": "0.1.0",
  "identifier": "com.jamesdumitru.sonyebooklibraryrevival",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Setup eBook Library Revival",
        "width": 1640,
        "height": 1040,
        "minWidth": 1640,
        "minHeight": 1040,
        "center": true,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "icon": ["icons/icon.png", "icons/icon.icns"]
  }
}
