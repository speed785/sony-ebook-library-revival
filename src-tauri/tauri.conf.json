{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sony eBook Library Revival",
  "version": "0.1.0",
  "identifier": "com.jamesdumitru.sonyebooklibraryrevival",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Sony eBook Library Revival",
        "width": 1640,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 800,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "poppler-utils"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
